```elixir
reconstructed_fundamentals =
  for win <-
        Enum.concat([speeches_windows, impulses, preempted]) do
    pairs =
      win
      |> Nx.devectorize(keep_names: false)
      |> Nx.vectorize(:windowx)
      |> Nx.multiply(Nx.reshape(hann, {:auto}))
      |> Nx.devectorize()
      |> then(
        &if(Nx.axis_size(&1, 0) |> Nx.to_number() |> rem(2) == 0,
          do: &1,
          else: Nx.concatenate([&1, Nx.broadcast(0, {1, 512})])
        )
      )
      |> Nx.reshape({:auto, 2, 512})
      |> Nx.transpose(axes: [1, 0, 2])
      |> Nx.reshape({2, :auto})

    offset = 256

    Nx.add(
      Nx.concatenate([Nx.broadcast(0, {offset}), pairs[1]], axis: 0),
      Nx.concatenate([pairs[0], Nx.broadcast(0, {offset})], axis: 0)
    )
    |> Nx.new_axis(0)
  end

[speech1, speech2]
|> Enum.concat(reconstructed_fundamentals)
|> KinoPhonograph.WavePlot.plot(
  labels: [
    "speech 1 original",
    "speech 2 original",
    "speech 1 reconstruction from spectogram",
    "speech 2 reconstruction from spectogram",
    "speech 1 fundamental reconstruction",
    "speech 2 fundamental reconstruction"
  ],
  titel: "Waveforms",
  width: 380,
  x_axis: "time",
  y_axis: "amplitude",
  background: {0, 0.2, 0.5, 1},
  foreground: {1, 1, 1, 1},
  ranges: [
    # highlight the slice ranges in the first to plots
    {slice1_start, slice1_end, {0.7, 0.0, 0.0, 1.0}},
    {slice2_start, slice2_end, {0.7, 0.0, 0.0, 1.0}},
    {slice1_start, slice1_end, {0.7, 0.0, 0.0, 1.0}},
    {slice2_start, slice2_end, {0.7, 0.0, 0.0, 1.0}}
  ]
)
```

