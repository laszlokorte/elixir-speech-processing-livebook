```elixir
for {windows, {title, _speech, sr}} <- speeches_windows |> Enum.zip(speeches) do
  winsize = Nx.axis_size(windows, 1)
  hann = Hann.window(size: winsize)

  premp =
    windows
    |> Nx.new_axis(1)
    |> Nx.conv(Nx.tensor([[[-0.95, 1]]]), padding: :same)
    |> Nx.squeeze(axes: [1])
    |> Nx.multiply(hann)
    |> Nx.to_list()

  damped = premp

  data =
    windows
    |> Nx.to_list()
    |> Enum.zip(damped)
    |> Enum.with_index()
    |> Enum.flat_map(fn {{window, dwin}, w} ->
      window
      |> Enum.zip(dwin)
      |> Enum.with_index()
      |> Enum.flat_map(fn {{a, b}, c} ->
        [
          %{
            x: (w * 512 / 2 + c) / sr,
            y: a,
            window: w,
            color: "original"
          },
          %{
            x: (w * 512 / 2 + c) / sr,
            y: b,
            window: w,
            color: "hann-scaled"
          }
        ]
      end)
    end)

  VegaLite.new(
    width: 600,
    title: "Spectrum of Window Slice: #{title}"
  )
  |> VegaLite.data_from_values(data)
  |> VegaLite.mark(:line)
  |> VegaLite.encode_field(:color, "color", type: :nominal, scale: [range: ["red", "blue"]])
  |> VegaLite.encode_field(:x, "x",
    type: :quantitative,
    axis: [title: "Time (s)", nice: false],
    scale: [nice: false, round: false]
  )
  |> VegaLite.encode_field(:y, "y",
    type: :quantitative,
    scale: [domain: [-0.1, 0.1]],
    axis: [title: "Amplitude"]
  )
  |> VegaLite.transform(filter: "datum.window == window ")
end
|> then(&VegaLite.concat(VegaLite.new(title: "Spectra"), &1, :vertical))
|> VegaLite.param("window",
  value: 0,
  bind: [
    name: "Window",
    input: :range,
    min: 0,
    max: Enum.map(speeches_windows, &(Nx.to_number(Nx.axis_size(&1, 0)) - 1)) |> Enum.min(),
    step: 1
  ]
)
